<%- include('partials/header') %>

<div class="container" style="max-width: 600px; margin: 40px auto; padding: 20px;">
    <div class="profile-wrapper">
        <div class="profile-card" style="background: white; padding: 30px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); text-align: left;">
            
            <% if (user.role === 'admin') { %>
                <h2>💼 Profil Admin Toko</h2>
            <% } else { %>
                <h2>👤 Profil Pembeli</h2>
            <% } %>
            
            <form action="/user/profile/update" method="POST" style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
                
                <!-- DATA UTAMA -->
                <div class="profile-form-group" style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-weight: bold; color: #333;">Username</label>
                    <input type="text" name="username" value="<%= user.username %>" required style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>

                <div class="profile-form-group" style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-weight: bold; color: #333;">Email Akun</label>
                    <input type="email" name="email" value="<%= user.email %>" required style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>

                <div class="profile-form-group" style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-weight: bold; color: #333;">Status Role</label>
                    <input type="text" value="<%= user.role.toUpperCase() %>" readonly style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5; border-radius: 4px; font-weight: bold; color: #007bff;">
                </div>
                
                <div class="profile-form-group" style="display: flex; flex-direction: column; gap: 5px;">
                    <% if (user.role === 'admin') { %>
                        <label for="phone" style="font-weight: bold;">Nomor Official Toko / CS</label>
                        <input type="text" id="phone" name="phone" placeholder="Contoh: 0812345..." value="<%= user.phone || '' %>" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    <% } else { %>
                        <label for="phone" style="font-weight: bold;">Nomor HP / WhatsApp Pembeli</label>
                        <input type="text" id="phone" name="phone" placeholder="Contoh: 0812345..." value="<%= user.phone || '' %>" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    <% } %>
                </div>
                
                <div class="profile-form-group" style="display: flex; flex-direction: column; gap: 5px;">
                    <% if (user.role === 'admin') { %>
                        <label for="address" style="font-weight: bold;">Alamat Utama Toko / Gudang</label>
                        <textarea id="address" name="address" rows="4" placeholder="Masukkan alamat titik jemput kurir, Lek..." style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; resize: vertical;"><%= user.address || '' %></textarea>
                    <% } else { %>
                        <label for="address" style="font-weight: bold;">Alamat Lengkap Rumah (Tujuan Pengiriman)</label>
                        <textarea id="address" name="address" rows="4" placeholder="Masukkan alamat pengiriman nota/barang, Lek..." style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; resize: vertical;"><%= user.address || '' %></textarea>
                    <% } %>
                </div>
                
                <button type="submit" class="btn-save-profile" style="padding: 12px; background: #ffc107; color: #212529; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 14px; margin-top: 10px;">Simpan Perubahan Data</button>
                
            </form>
            
        </div>
    </div>
</div>

<%- include('partials/footer') %>