<%- include('partials/header') %>

<div class="container" style="display: flex; gap: 30px; margin-top: 30px; min-height: 70vh;">
    
    <div style="flex: 1; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); max-width: 300px; height: fit-content;">
        <h3 style="color: #2c3e50; margin-bottom: 20px; border-bottom: 2px solid #f4f6f9; padding-bottom: 10px;">Layanan Toko</h3>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px;">
            <li><a href="/" style="text-decoration: none; color: #333; font-weight: 600;">Kembali ke Katalog</a></li>
            <li><a href="/cart" style="text-decoration: none; color: #333;"></a></li>
            <li><a href="/user/profile" style="text-decoration: none; color: #333;">Profil Saya</a></li>
        </ul>
        <hr style="margin: 20px 0; border: none; border-top: 1px solid #eee;">
        <p style="font-size: 13px; color: #777; line-height: 1.5;">
           
        </p>
    </div>

    <div style="flex: 3; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; overflow: hidden; border: 1px solid #eef2f5;">
        
        <div style="background: #007bff; color: white; padding: 20px; font-weight: bold; font-size: 18px; display: flex; align-items: center; gap: 10px;">
            Hubungi Customer Service 
        </div>

        <div id="chatMessages" style="flex: 1; padding: 20px; overflow-y: auto; background: #fdfdfd; min-height: 400px; max-height: 450px;">
            <div style="background: #e9ecef; padding: 10px 15px; border-radius: 8px; margin-bottom: 15px; max-width: 70%; font-size: 14px; color: #333;">
                <strong>Sistem:</strong> Selamat datang di chat real-time
            </div>
        </div>

        <form id="chatForm" style="display: flex; border-top: 1px solid #eee; background: #fff; padding: 15px; gap: 10px;">
            <input type="text" id="chatInput" placeholder="Ketik pesan kelen di sini, Lek..." required autocomplete="off"
                style="flex: 1; padding: 12px 15px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; outline: none;">
            <button type="submit" style="padding: 12px 25px; background: #007bff; color: white; border: none; border-radius: 6px; font-weight: bold; font-size: 14px; cursor: pointer;">
                Kirim
            </button>
        </form>
    </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');
    const chatMessages = document.getElementById('chatMessages');

    const username = "<%= user ? user.username : 'Guest Lek' %>";

    chatForm.addEventListener('submit', (e) => {
        e.preventDefault();
        if (chatInput.value.trim()) {
            // Kirim data pesan ke server
            socket.emit('kirim-pesan', {
                sender: username,
                message: chatInput.value
            });
            chatInput.value = '';
        }
    });
    socket.on('terima-pesan', (data) => {
        const messageElement = document.createElement('div');
        const isMe = data.sender === username;
        messageElement.style.marginBottom = '15px';
        messageElement.style.padding = '10px 15px';
        messageElement.style.borderRadius = '8px';
        messageElement.style.maxWidth = '70%';
        messageElement.style.fontSize = '14px';
        
        if (isMe) {
            messageElement.style.background = '#d1e7dd';
            messageElement.style.marginLeft = 'auto';
            messageElement.style.color = '#0f5132';
            messageElement.innerHTML = `<strong>Anda:</strong> ${data.message}`;
        } else {
            messageElement.style.background = '#e9ecef';
            messageElement.style.marginRight = 'auto';
            messageElement.style.color = '#333';
            messageElement.innerHTML = `<strong>${data.sender}:</strong> ${data.message}`;
        }

        chatMessages.appendChild(messageElement);
        chatMessages.scrollTop = chatMessages.scrollHeight; 
    });
</script>

<%- include('partials/footer') %>