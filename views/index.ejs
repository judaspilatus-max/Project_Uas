<%- include('partials/header') %>


<div style="max-width: 1200px; margin: 40px auto; padding: 0 20px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px;">
        
    
        <h2 style="margin: 0; color: #2c3e50; font-size: 28px; font-weight: bold; display: flex; align-items: center; gap: 10px;">
            Katalog Produk Terbaru
        </h2>

        <form action="/" method="GET" style="display: flex; gap: 8px; margin: 0;">
            <input 
                type="text" 
                name="search" 
                placeholder="Cari barang dagangan..." 
                value="<%= typeof searchKeyword !== 'undefined' ? searchKeyword : '' %>"
                style="padding: 10px 15px; border: 1px solid #ccc; border-radius: 6px; width: 240px; font-size: 14px; outline: none; transition: border 0.2s;"
                onfocus="this.style.border='1px solid #007bff'"
                onblur="this.style.border='1px solid #ccc'"
            >
            <button 
                type="submit" 
                style="padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 14px; transition: background 0.2s;"
                onmouseover="this.style.background='#0056b3'"
                onmouseout="this.style.background='#007bff'"
            >
                Cari
            </button>
        </form>
    </div>
    <% if (products && products.length > 0) { %>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px;">
            
            <% products.forEach(product => { %>
                <div class="card" style="border: 1px solid #eef2f5; padding: 20px; border-radius: 12px; background: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.02); display: flex; flex-direction: column; justify-content: space-between; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    
                    <div>
                        <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" 
                             style="width: 100%; max-height: 200px; object-fit: contain; margin-bottom: 15px;">
                        
                        <h3 style="font-size: 18px; color: #2c3e50; margin: 0 0 8px 0; font-weight: bold;"><%= product.name %></h3>
                        <p style="font-size: 14px; color: #777; margin: 0 0 12px 0; line-height: 1.4;"><%= product.description || 'Laptop Gaming terbaik' %></p>
                    </div>

                    <div>
                        <p style="color: #e74c3c; font-weight: bold; font-size: 20px; margin: 0 0 5px 0;">
                            Rp <%= product.price.toLocaleString('id-ID') %>
                        </p>
                        <p style="font-size: 13px; color: #555; margin: 0 0 15px 0;">
                            Stok Tersedia: <strong style="color: #2c3e50;"><%= product.stock %> pcs</strong>
                        </p>

                        <% if (user && user.role === 'user') { %>
                            <% if (product.stock > 0) { %>
                                <div style="display: flex; flex-direction: column; gap: 10px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span style="font-size: 13px; color: #555;">Beli Berapa:</span>
                                        <input type="number" id="qty_<%= product.id %>" value="1" min="1" max="<%= product.stock %>" required 
                                               style="width: 60px; padding: 6px; border-radius: 6px; border: 1px solid #ccc; text-align: center;">
                                    </div>
                                    <button type="button" onclick="kirimKeKeranjang('<%= product.id %>')" style="width: 100%; padding: 12px; background: #007bff; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">
                                        🛒 Masuk Keranjang
                                    </button>
                                </div>
                            <% } else { %>
                                <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 6px; text-align: center; font-weight: bold;">
                                    Stok Habis, Lek!
                                </div>
                            <% } %>
                        <% } else if (user && user.role === 'admin') { %>
                            <div style="background: #e2e3e5; color: #383d41; padding: 10px; border-radius: 6px; text-align: center; font-size: 13px; font-weight: bold;">
                                Mode Pantau Stok Admin
                            </div>
                        <% } else { %>
                            <a href="/login" style="display: block; text-align: center; padding: 12px; background: #6c757d; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;">
                                🔒 Silakan Login untuk Membeli
                            </a>
                        <% } %>
                    </div>

                </div>
            <% }) %>
        </div>

    <% } else { %>
        <!-- TAMPILAN ESTETIK KALAU BARANG TIDAK ADA DI DATABASE LEK -->
        <div style="text-align: center; padding: 60px 20px; background: #fff; border: 2px dashed #e2e8f0; border-radius: 12px; max-width: 600px; margin: 30px auto; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <div style="font-size: 50px; margin-bottom: 15px;">🔍</div>
            <h3 style="margin: 0 0 10px 0; font-size: 20px; color: #2c3e50; font-weight: bold;">
                Waduh Lek, barang tidak ada!
            </h3>
            <p style="margin: 0; color: #718096; font-size: 15px; line-height: 1.5;">
                Produk dengan kata kunci "<span style="color: #e53e3e; font-weight: bold;"><%= searchKeyword %></span>" tidak ditemukan di database Mikroskil Shop.
            </p>
            <a href="/" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background: #edf2f7; color: #4a5568; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 14px; transition: background 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#edf2f7'">
                🔄 Lihat Semua Produk
            </a>
        </div>
    <% } %>

</div>

<script>
function kirimKeKeranjang(productId) {
    const kuantitas = document.getElementById('qty_' + productId).value;

    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            productId: productId,
            qty: kuantitas
        })
    })
    .then(res => {
        if (res.ok) {
            alert("Mantap Lek, barang berhasil masuk keranjang!");
            window.location.reload(); 
        } else {
            alert("Gagal menambahkan, Lek. Coba cek login kau dulu!");
        }
    })
    .catch(err => {
        console.error("Error koneksi:", err);
        alert("Ada error koneksi, Lek!");
    });
}
</script>

<%- include('partials/footer') %>