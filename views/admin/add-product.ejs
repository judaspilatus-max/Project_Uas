<%- include('../partials/header') %> <!-- Sesuaikan path include jika filenya di subfolder admin -->

<div class="admin-page-container">
    <div class="admin-form-card">
        <div class="admin-form-header">
            <h2>📦 Tambah Produk Toko Baru</h2>
            <p>Masukkan informasi produk kelen dengan lengkap dan jelas, Lek.</p>
        </div>

        <!-- Tambahkan enctype jika kamu mengunggah file gambar dengan multer -->
        <form action="/admin/add-product" method="POST" enctype="multipart/form-data" class="admin-product-form">
            
            <div class="admin-form-group">
                <label for="name">Nama Produk</label>
                <input type="text" id="name" name="name" placeholder="Masukkan nama barang dagangan..." required>
            </div>

            <div class="admin-form-group">
                <label for="description">Deskripsi Singkat</label>
                <textarea id="description" name="description" rows="4" placeholder="Jelaskan kondisi atau spesifikasi produk, Lek..." required></textarea>
            </div>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label for="price">Harga Jual (Rupiah)</label>
                    <input type="number" id="price" name="price" placeholder="Contoh: 50000" min="0" required>
                </div>

                <div class="admin-form-group">
                    <label for="stock">Stok Awal</label>
                    <input type="number" id="stock" name="stock" placeholder="Contoh: 10" min="0" required>
                </div>
            </div>

            <div class="admin-form-group">
                <label for="image">Unggah Gambar Produk (.png / .jpg)</label>
                <div class="file-input-wrapper">
                    <input type="file" id="image" name="image" accept="image/*" required>
                </div>
            </div>

            <button type="submit" class="btn-submit-product">
                💾 Simpan ke Katalog
            </button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>