<%- include('../partials/header') %>

<div style="display: flex; gap: 20px; margin-bottom: 20px;">
    <a href="/admin/dashboard" style="padding: 10px 15px; background: #343a40; color: white; text-decoration: none; border-radius: 5px;">📦 List Pesanan Masuk</a>
    <a href="/admin/manage-products" style="padding: 10px 15px; background: #007bff; color: white; text-decoration: none; border-radius: 5px;">⚙️ Kelola CRUD Produk</a>
</div>

<h2>Dashboard Admin: Rekap Transaksi Masuk</h2>

<div style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
    <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
            <tr style="border-bottom: 2px solid #ddd; background: #f1f1f1;">
                <th style="padding: 10px;">ID Order</th>
                <th>Nama Pelanggan</th>
                <th>Total Belanja</th>
                <th>Waktu Transaksi</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                <% orders.forEach(row => { %>
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 10px;">#<%= row.id %></td>
                        <td><strong><%= row.username %></strong></td>
                        <td>Rp <%= row.total_price.toLocaleString() %></td>
                        <td><%= new Date(row.created_at).toLocaleString('id-ID') %></td>
                        <td>
                            <!-- FORM DROPDOWN UNTUK UPDATE STATUS -->
                          <!-- FORM DROPDOWN UNTUK UPDATE STATUS -->
<form action="/admin/update-order-status/<%= row.id %>" method="POST" style="display: inline-block; margin: 0;">
    <select name="status" onchange="this.form.submit()" class="pilihan-status status-<%= row.status %>">
        <!-- Sesuaikan value-nya murni dengan isi ENUM database kelen -->
        <option value="pending" <%= row.status === 'pending' ? 'selected' : '' %>>pending</option>
        <option value="success" <%= row.status === 'success' ? 'selected' : '' %>>success</option>
    </select>
</form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; padding: 20px; color: #777; font-style: italic;">Belum ada pesanan masuk, Lek.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>