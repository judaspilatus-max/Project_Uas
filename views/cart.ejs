<%- include('partials/header') %>

<div class="container" style="max-width: 1000px; margin: 40px auto; padding: 0 20px; min-height: 70vh;">
    <h2 style="color: #2c3e50; border-bottom: 2px solid #007bff; padding-bottom: 10px; margin-bottom: 30px;">🛒 Keranjang Belanjaan Kau</h2>

    <% if (cartItems.length === 0) { %>
        <div style="text-align: center; padding: 40px; background: #f8f9fa; border-radius: 8px;">
            <p style="font-size: 18px; color: #777;">Keranjang kau masih kosong melompong, Lek.</p>
            <a href="/" style="display: inline-block; margin-top: 15px; padding: 10px 20px; background: #007bff; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;">Gas Belanja!</a>
        </div>
    <% } else { %>
        <div style="background: white; border-radius: 12px; padding: 20px;">
            <p style="color: green; font-weight: bold;">Ada <%= cartItems.length %> barang di keranjang.</p>
            <!-- Tombol Checkout -->
            <form action="/cart/checkout" method="POST" style="margin-top: 20px;">
                <button type="submit" style="padding: 12px 25px; background: #2ecc71; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">🚀 CHECKOUT SEKARANG</button>
            </form>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>